# =============================================================================
# Cameroon Geospatial Data Portal — environment template
# Copy to .env and fill in. NEVER commit a real .env (it is git-ignored).
# All payment/cloud keys below are PLACEHOLDERS — supply SANDBOX keys only.
# =============================================================================

# ---- PostGIS / database ----
POSTGRES_USER=geoportal
POSTGRES_PASSWORD=change_me_local_dev
POSTGRES_DB=geoportal
POSTGRES_HOST=db
POSTGRES_PORT=5432
# SQLAlchemy / psycopg URL (used by API + worker)
DATABASE_URL=postgresql://geoportal:change_me_local_dev@db:5432/geoportal
# pgstac connection (STAC catalog lives in the same PostGIS instance)
PGSTAC_DSN=postgresql://geoportal:change_me_local_dev@db:5432/geoportal

# ---- Redis (Celery broker + result backend) ----
REDIS_URL=redis://redis:6379/0

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# JWT signing secret for auth (Phase 5). Generate a long random string.
JWT_SECRET=change_me_generate_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- Object storage: Cloudflare R2 (S3-compatible) ----
# Ask the user for these. Do NOT invent. Sandbox/dev bucket only for now.
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=cameroon-geoportal-cogs
R2_PUBLIC_BASE_URL=https://<your-public-r2-domain>

# ---- TiTiler ----
TITILER_PORT=8001
# Browser-facing base URLs the API hands to the frontend for tiles.
TITILER_PUBLIC_URL=http://localhost:8001
MARTIN_PUBLIC_URL=http://localhost:3000
# When COGs are public on R2, TiTiler reads them by URL.
GDAL_DISABLE_READDIR_ON_OPEN=EMPTY_DIR
CPL_VSIL_CURL_ALLOWED_EXTENSIONS=.tif,.tiff,.cog

# ---- Martin (vector tiles from PostGIS) ----
MARTIN_PORT=3000

# ---- Frontend (Vite) ----
# Public base URLs the browser uses to reach each service.
VITE_API_BASE_URL=http://localhost:8000
VITE_TITILER_BASE_URL=http://localhost:8001
VITE_MARTIN_BASE_URL=http://localhost:3000

# ---- Data-source credentials (Phase 2 ingestion) ----
# NASA Earthdata (SRTM) — https://urs.earthdata.nasa.gov
EARTHDATA_USERNAME=REPLACE_ME
EARTHDATA_PASSWORD=REPLACE_ME
# Copernicus Data Space (Sentinel-2) — https://dataspace.copernicus.eu
COPERNICUS_USERNAME=REPLACE_ME
COPERNICUS_PASSWORD=REPLACE_ME

# ---- Payments (Phase 5) — SANDBOX KEYS ONLY ----
# Stripe (cards) — test mode keys (sk_test_..., pk_test_...)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Flutterwave (mobile money: MTN MoMo / Orange Money) — sandbox keys
FLW_PUBLIC_KEY=FLWPUBK_TEST-REPLACE_ME
FLW_SECRET_KEY=FLWSECK_TEST-REPLACE_ME
FLW_ENCRYPTION_KEY=FLWSECK_TESTREPLACE_ME
